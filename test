    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "x_train = np.array([18.5, 22.0, 25.5, 28.0, 32.0, 35.5])\n",
    "y_train = np.array([85, 95, 110, 125, 145, 160])\n",
    "\n",
    "print(\"x_train =\", x_train)\n",
    "print(\"y_train =\", y_train)\n",
    "\n",
    "plt.figure(figsize=(8,5))\n",
    "\n",
    "plt.scatter(x_train, y_train)\n",
    "\n",
    "plt.title(\"Relation entre IMC et Glycémie\")\n",
    "plt.xlabel(\"IMC\")\n",
    "plt.ylabel(\"Glycémie (mg/dL)\")\n",
    "\n",
    "plt.show()\n",
    "\n",
    "def compute_cost(x, y, w, b):\n",
    "    \n",
    "    m = x.shape[0]\n",
    "    \n",
    "    total_cost = 0\n",
    "    \n",
    "    for i in range(m):\n",
    "        \n",
    "        f_wb = w * x[i] + b\n",
    "        \n",
    "        cost = (f_wb - y[i]) ** 2\n",
    "        \n",
    "        total_cost += cost\n",
    "        \n",
    "    total_cost = total_cost / (2 * m)\n",
    "    \n",
    "    return total_cost\n",
    "\n",
    "cost1 = compute_cost(x_train, y_train, 2, 40)\n",
    "cost2 = compute_cost(x_train, y_train, 3, 30)\n",
    "cost3 = compute_cost(x_train, y_train, 4, 10)\n",
    "\n",
    "print(\"\\n===== Coûts calculés =====\")\n",
    "print(\"Coût pour (w=2, b=40) :\", cost1)\n",
    "print(\"Coût pour (w=3, b=30) :\", cost2)\n",
    "print(\"Coût pour (w=4, b=10) :\", cost3)\n",
    "\n",
    "def gradient_descent(x, y, w_in, b_in, alpha, num_iters):\n",
    "    \n",
    "    m = x.shape[0]\n",
    "    \n",
    "    J_history = []\n",
    "    \n",
    "    w = w_in\n",
    "    b = b_in\n",
    "    \n",
    "    for iteration in range(num_iters):\n",
    "        \n",
    "        dj_dw = 0\n",
    "        dj_db = 0\n",
    "        \n",
    "        for i in range(m):\n",
    "            \n",
    "            f_wb = w * x[i] + b\n",
    "            \n",
    "            dj_dw += (f_wb - y[i]) * x[i]\n",
    "            dj_db += (f_wb - y[i])\n",
    "        \n",
    "        dj_dw = dj_dw / m\n",
    "        dj_db = dj_db / m\n",
    "        \n",
    "        w = w - alpha * dj_dw\n",
    "        b = b - alpha * dj_db\n",
    "        \n",
    "        cost = compute_cost(x, y, w, b)\n",
    "        \n",
    "        J_history.append(cost)\n",
    "    \n",
    "    return w, b, J_history\n",
    "\n",
    "\n",
    "w_init = 0\n",
    "b_init = 0\n",
    "\n",
    "alpha = 1e-4\n",
    "iterations = 1000\n",
    "\n",
    "w_final, b_final, J_history = gradient_descent(\n",
    "    x_train,\n",
    "    y_train,\n",
    "    w_init,\n",
    "    b_init,\n",
    "    alpha,\n",
    "    iterations\n",
    ")\n",
    "\n",
    "print(\"\\n===== Paramètres finaux =====\")\n",
    "print(\"w =\", w_final)\n",
    "print(\"b =\", b_final)\n",
    "\n",
    "y_pred = w_final * x_train + b_final\n",
    "\n",
    "plt.figure(figsize=(8,5))\n",
    "\n",
    "plt.scatter(x_train, y_train, label=\"Données réelles\")\n",
    "\n",
    "plt.plot(x_train, y_pred, label=\"Droite de régression\")\n",
    "\n",
    "plt.title(\"Régression Linéaire : IMC vs Glycémie\")\n",
    "plt.xlabel(\"IMC\")\n",
    "plt.ylabel(\"Glycémie (mg/dL)\")\n",
    "\n",
    "plt.legend()\n",
    "\n",
    "plt.show()\n",
    "\n",
    "imc_patient = 30\n",
    "\n",
    "prediction = w_final * imc_patient + b_final\n",
    "\n",
    "print(\"\\n===== Prédiction =====\")\n",
    "print(\"Glycémie prédite pour IMC = 30 :\", prediction)\n",
    "\n",
    "\n",
    "plt.figure(figsize=(8,5))\n",
    "\n",
    "plt.plot(J_history)\n",
    "\n",
    "plt.title(\"Évolution du coût\")\n",
    "plt.xlabel(\"Itérations\")\n",
    "plt.ylabel(\"Coût J(w,b)\")\n",
    "\n",
    "plt.show()"
   ]
